{
  "version": 8,
  "name": "OSRM MVT Debug (minimal)",
  "sources": {
    "osrm": {
      "type": "vector",
      "tiles": [
        "https://router.project-osrm.org/tile/v1/car/tile({x},{y},{z}).mvt"
      ],
      "minzoom": 12,
      "maxzoom": 19
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#111"
      }
    },
    {
      "id": "speeds outline",
      "type": "line",
      "source": "osrm",
      "source-layer": "speeds",
      "filter": ["==", "$type", "LineString"],
      "layout": {
        "visibility": "visible",
        "line-cap": "round"
      },
      "paint": {
        "line-width": {
          "base": 1.5,
          "stops": [
            [12.5, 4],
            [14, 6],
            [18, 24]
          ]
        },
        "line-color": "hsl(0, 0%, 0%)",
        "line-offset": {
          "base": 1.5,
          "stops": [
            [12.5, 0.25],
            [14, 1],
            [18, 9]
          ]
        }
      },
      "minzoom": 12
    },
    {
      "id": "speeds small components",
      "type": "line",
      "source": "osrm",
      "source-layer": "speeds",
      "filter": [
        "all",
        ["==", "$type", "LineString"],
        ["==", "is_small", true]
      ],
      "layout": {
        "visibility": "visible",
        "line-cap": "round"
      },
      "paint": {
        "line-width": {
          "base": 1.5,
          "stops": [
            [12.5, 6],
            [14, 8],
            [18, 28]
          ]
        },
        "line-color": "#ff37ef",
        "line-offset": {
          "base": 1.5,
          "stops": [
            [12.5, 0.25],
            [14, 1],
            [18, 9]
          ]
        }
      },
      "minzoom": 12
    },
    {
      "id": "speeds < 10",
      "type": "line",
      "source": "osrm",
      "source-layer": "speeds",
      "filter": ["all", ["==", "$type", "LineString"], ["<=", "speed", 10]],
      "layout": {
        "visibility": "visible",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#5e4fa2",
        "line-width": {
          "base": 1.5,
          "stops": [
            [12.5, 0.5],
            [14, 2],
            [18, 18]
          ]
        },
        "line-offset": {
          "base": 1.5,
          "stops": [
            [12.5, 0.25],
            [14, 1],
            [18, 9]
          ]
        }
      },
      "minzoom": 12
    },
    {
      "id": "speeds 10-20",
      "type": "line",
      "source": "osrm",
      "source-layer": "speeds",
      "filter": [
        "all",
        ["==", "$type", "LineString"],
        ["all", ["<=", "speed", 20], [">", "speed", 10]]
      ],
      "layout": {
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#3288bd",
        "line-width": {
          "base": 1.5,
          "stops": [
            [12.5, 0.5],
            [14, 2],
            [18, 18]
